# Copy to .env and fill real values.
# Compatible with OpenAI-compatible providers (DashScope/Bailian, DeepSeek, OpenAI, OpenRouter, SiliconFlow, etc.)

OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# Optional embedding model (DashScope text-embedding-v3 or OpenAI text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-v3